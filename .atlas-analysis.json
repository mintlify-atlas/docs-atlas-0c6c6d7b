  "keyFeatures": [
    "Topic-centric discussion rooms (Spaces) with public and private visibility",
    "Real-time messaging via Socket.IO",
    "Media sharing — images, videos, and audio in messages",
    "Message appreciation (reactions/likes) system",
    "Tag-based and full-text search for discovering spaces",
    "Trending and personalized space recommendations",
    "User profiles with contribution stats",
    "Push notifications for activity updates",
    "OTP-based email verification and password reset",
    "Animated bottom tab navigation with bold card-driven UI"
  ],
  "publicApiSurface": [
    "POST /api/auth/signup",
    "POST /api/auth/login",
    "POST /api/auth/verify-otp",
    "POST /api/auth/forgot-password",
    "POST /api/auth/reset-password",
