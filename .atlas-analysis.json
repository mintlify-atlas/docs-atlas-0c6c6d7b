    "GET /api/spaces/recommended",
    "GET /api/spaces/my",
    "POST /api/spaces",
    "GET /api/spaces/:spaceId",
    "POST /api/spaces/:spaceId/join",
    "GET /api/spaces/search?q=",
    "GET /api/spaces/tag/:tag",
    "GET /api/messages/:spaceId",
    "POST /api/messages/:spaceId",
    "POST /api/messages/:spaceId/:messageId/appreciate",
    "DELETE /api/messages/:spaceId/:messageId",
    "GET /api/profile/me",
    "PUT /api/profile/username",
    "PUT /api/profile/bio",
    "PUT /api/profile/picture",
    "PUT /api/profile/password",
